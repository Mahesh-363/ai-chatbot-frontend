# ─────────────────────────────────────────────────────────────
#  ALL OPTIONS BELOW ARE 100% FREE — NO CREDIT CARD NEEDED
# ─────────────────────────────────────────────────────────────

# Choose your provider: groq | gemini | ollama
VITE_AI_PROVIDER=groq

# ── OPTION 1: Groq (RECOMMENDED — fast & free) ───────────────
# 1. Go to https://console.groq.com
# 2. Sign up (free, no card)
# 3. Create API Key → paste below
VITE_GROQ_API_KEY=gsk_your_groq_key_here

# ── OPTION 2: Google Gemini (free tier) ──────────────────────
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API key" (free, no card)
# 3. Paste below, change VITE_AI_PROVIDER=gemini
# VITE_GEMINI_API_KEY=AIza_your_gemini_key_here

# ── OPTION 3: Ollama (fully local, no internet after setup) ───
# 1. Download from https://ollama.com/download
# 2. Run: ollama pull llama3
# 3. Change VITE_AI_PROVIDER=ollama (no key needed!)
# VITE_OLLAMA_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=llama3
